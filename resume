03c/td\u003e\u003c/tr\u003e\n\u003ctr\u003e\u003ctd style=\"padding:3px 8px 3px 56px;color:#c9d1d9;border:none;\"\u003e\u0026#9500;\u0026#9472;\u0026#9472; \u003cspan style=\"color:#58a6ff;font-weight:600;\"\u003eTLDB/\u003c/span\u003e \u003cspan style=\"color:#8b949e;\"\u003e- ODBC DB 계층 (Connection, DBPool, Query)\u003c/span\u003e\u003c/td\u003e\u003c/tr\u003e\n\u003ctr\u003e\u003ctd style=\"padding:3px 8px 3px 56px;color:#c9d1d9;border:none;\"\u003e\u0026#9500;\u0026#9472;\u0026#9472; \u003cspan style=\"color:#58a6ff;font-weight:600;\"\u003eASE/\u003c/span\u003e \u003cspan style=\"color:#8b949e;\"\u003e- 비동기 Worker 프레임워크\u003c/span\u003e\u003c/td\u003e\u003c/tr\u003e\n\u003ctr\u003e\u003ctd style=\"padding:3px 8px 3px 56px;color:#c9d1d9;border:none;\"\u003e\u0026#9492;\u0026#9472;\u0026#9472; \u003cspan style=\"color:#58a6ff;font-weight:600;\"\u003eflatbuffers/\u003c/span\u003e \u003cspan style=\"color:#8b949e;\"\u003e- FlatBuffers 직렬화\u003c/span\u003e\u003c/td\u003e\u003c/tr\u003e\n\u003ctr\u003e\u003ctd style=\"padding:3px 8px 3px 32px;color:#c9d1d9;border:none;\"\u003e\u0026#9500;\u0026#9472;\u0026#9472; \u003cspan style=\"color:#d29922;font-weight:600;\"\u003e(external)/\u003c/span\u003e \u003cspan style=\"color:#8b949e;\"\u003e- 외부 라이브러리\u003c/span\u003e\u003c/td\u003e\u003c/tr\u003e\n\u003ctr\u003e\u003ctd style=\"padding:3px 8px 3px 56px;color:#c9d1d9;border:none;\"\u003e\u0026#9500;\u0026#9472;\u0026#9472; \u003cspan style=\"color:#d29922;font-weight:600;\"\u003eNxNet/\u003c/span\u003e \u003cspan style=\"color:#8b949e;\"\u003e- Windows IOCP 네트워크 (IOCPManager, Session)\u003c/span\u003e\u003c/td\u003e\u003c/tr\u003e\n\u003ctr\u003e\u003ctd style=\"padding:3px 8px 3px 56px;color:#c9d1d9;border:none;\"\u003e\u0026#9500;\u0026#9472;\u0026#9472; \u003cspan style=\"color:#d29922;font-weight:600;\"\u003eNxBase/\u003c/span\u003e \u003cspan style=\"color:#8b949e;\"\u003e- 유틸리티, Singleton 등\u003c/span\u003e\u003c/td\u003e\u003c/tr\u003e\n\u003ctr\u003e\u003ctd style=\"padding:3px 8px 3px 56px;color:#c9d1d9;border:none;\"\u003e\u0026#9492;\u0026#9472;\u0026#9472; \u003cspan style=\"color:#d29922;font-weight:600;\"\u003eNxProtocol/\u003c/span\u003e \u003cspan style=\"color:#8b949e;\"\u003e- 프로토콜 정의\u003c/span\u003e\u003c/td\u003e\u003c/tr\u003e\n\u003ctr\u003e\u003ctd style=\"padding:3px 8px 3px 32px;color:#c9d1d9;border:none;\"\u003e\u0026#9500;\u0026#9472;\u0026#9472; \u003cspan style=\"color:#8b949e;font-weight:600;\"\u003ePROTOCOL/\u003c/span\u003e \u003cspan style=\"color:#8b949e;\"\u003e- 프로토콜 헤더 (GAME/DBA/BILLING/GM/LOGIN/SYSTEM)\u003c/span\u003e\u003c/td\u003e\u003c/tr\u003e\n\u003ctr\u003e\u003ctd style=\"padding:3px 8px 3px 32px;color:#c9d1d9;border:none;\"\u003e\u0026#9500;\u0026#9472;\u0026#9472; \u003cspan style=\"color:#8b949e;font-weight:600;\"\u003eBattle/\u003c/span\u003e \u003cspan style=\"color:#8b949e;\"\u003e- 전투 라이브러리\u003c/span\u003e\u003c/td\u003e\u003c/tr\u003e\n\u003ctr\u003e\u003ctd style=\"padding:3px 8px 3px 32px;color:#c9d1d9;border:none;\"\u003e\u0026#9500;\u0026#9472;\u0026#9472; \u003cspan style=\"color:#8b949e;font-weight:600;\"\u003eLogDBAgent/\u003c/span\u003e \u003cspan style=\"color:#8b949e;\"\u003e- 로그 DB 에이전트\u003c/span\u003e\u003c/td\u003e\u003c/tr\u003e\n\u003ctr\u003e\u003ctd style=\"padding:3px 8px 3px 32px;color:#c9d1d9;border:none;\"\u003e\u0026#9500;\u0026#9472;\u0026#9472; \u003cspan style=\"color:#8b949e;font-weight:600;\"\u003eXXXXXServer/\u003c/span\u003e \u003cspan style=\"color:#8b949e;\"\u003e- 보조 서버\u003c/span\u003e\u003c/td\u003e\u003c/tr\u003e\n\u003ctr\u003e\u003ctd style=\"padding:3px 8px 3px 32px;color:#c9d1d9;border:none;\"\u003e\u0026#9492;\u0026#9472;\u0026#9472; \u003cspan style=\"color:#8b949e;font-weight:600;\"\u003eScript/\u003c/span\u003e \u003cspan style=\"color:#8b949e;\"\u003e- 빌드/운영 스크립트\u003c/span\u003e\u003c/td\u003e\u003c/tr\u003e\n\u003c/table\u003e\n\u003c/div\u003e\n\u003c/div\u003e\n\n\u003c!-- 10. 네트워크 계층 --\u003e\n\u003cdiv id=\"network\" style=\"background:#161b22;border:1px solid #30363d;border-radius:12px;padding:28px 32px;margin-bottom:24px;\"\u003e\n\u003ch2 style=\"color:#e6edf3;font-size:1.4em;margin:0 0 20px;padding-bottom:12px;border-bottom:1px solid #30363d;\"\u003e10. 네트워크 계층 상세 (TLNET 중심, NxNet 분리)\u003c/h2\u003e\n\n\u003cdiv style=\"padding:14px 20px;border-radius:8px;margin:0 0 16px;font-size:0.9em;color:#c9d1d9;border-left:3px solid #58a6ff;background:rgba(88,166,255,0.08);\"\u003e\n\u003cp style=\"color:#c9d1d9;margin:0;\"\u003e\u003cstrong style=\"color:#58a6ff;\"\u003e★ TLNET(Boost.Asio)\u003c/strong\u003e이 메시지 처리의 중심. 클라이언트 접속, 패킷 파싱, GameWorker 전달까지 모두 TLNET이 담당. \u003cstrong style=\"color:#d29922;\"\u003eNxNet(Windows IOCP)\u003c/strong\u003e은 기술적으로 서버간 통신을 지원하나, 현실에서는 \u003cstrong style=\"color:#d29922;\"\u003e모니터링 툴 전용\u003c/strong\u003e으로만 운용됩니다.\u003c/p\u003e\n\u003c/div\u003e\n\n\u003ctable style=\"width:100%;border-collapse:collapse;font-size:0.9em;\"\u003e\n\u003ctr\u003e\n\u003cth style=\"background:#1c2333;color:#e6edf3;padding:10px 14px;text-align:left;font-weight:600;border-bottom:2px solid #30363d;\"\u003e항목\u003c/th\u003e\n\u003cth style=\"background:#1c2333;color:#58a6ff;padding:10px 14px;text-align:left;font-weight:600;border-bottom:2px solid #30363d;\"\u003e★ TLNET (메인)\u003c/th\u003e\n\u003cth style=\"background:#1c2333;color:#d29922;padding:10px 14px;text-align:left;font-weight:600;border-bottom:2px solid #30363d;\"\u003e※ NxNet (모니터링 전용)\u003c/th\u003e\n\u003c/tr\u003e\n\u003ctr\u003e\n\u003ctd style=\"padding:9px 14px;border-bottom:1px solid #30363d;color:#e6edf3;font-weight:600;\"\u003eI/O 모델\u003c/td\u003e\n\u003ctd style=\"padding:9px 14px;border-bottom:1px solid #30363d;color:#c9d1d9;\"\u003eBoost.Asio (io_context)\u003c/td\u003e\n\u003ctd style=\"padding:9px 14px;border-bottom:1px solid #30363d;color:#c9d1d9;\"\u003eWindows IOCP\u003c/td\u003e\n\u003c/tr\u003e\n\u003ctr\u003e\n\u003ctd style=\"padding:9px 14px;border-bottom:1px solid #30363d;color:#e6edf3;font-weig