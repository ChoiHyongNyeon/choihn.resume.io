<script>
let DATA = {};
let currentSection = 'career-all';
let currentView = 'summary';

// 사용자 설정 default view 로 currentView 초기화 + 토글 active 동기화
function applyDefaultView() {
  const valid = ['summary', 'detail', 'timeline'];
  const def = valid.includes(DATA.career_default_view) ? DATA.career_default_view : 'summary';
  currentView = def;
  const idx = Math.max(0, valid.indexOf(def));
  document.querySelectorAll('.toggle-btn').forEach((b, i) => {
    b.classList.toggle('active', i === idx);
  });
}

// HTML escape + 인라인 강조 마커 변환
//   **text** 또는 ++text++  →  <strong>text</strong>
// 빌드 결과엔 마커가 보이지 않고 볼드만 적용됨.
function fmt(text) {
  if (text == null) return '';
  let s = String(text)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
  s = s.replace(/\*\*([^\n]+?)\*\*/g, '<strong>$1</strong>');
  s = s.replace(/\+\+([^\n]+?)\+\+/g, '<strong>$1</strong>');
  return s;
}

// 블록 변환 — 자유 텍스트 안의 특수 마커를 HTML 로:
//   ```mermaid ... ```   → 다이어그램 SVG (mermaid.run)
//   ![이미지ID]          → DATA.images[ID] 의 base64 이미지 <img>
//   그 외                → fmt() 통과 (escape + 인라인 볼드 마커)
// 사용 위치: 자유 텍스트 필드 (자기소개서 content, profile.objective 등).
function fmtBlock(text) {
  if (text == null) return '';
  const blocks = [];
  const images = DATA.images || {};
  let s = String(text);
  // 1) mermaid 코드 블록 추출 (escape 전에)
  s = s.replace(/```mermaid\s*\n([\s\S]+?)\n```/g, (m, code) => {
    blocks.push({ kind: 'mermaid', code: code.trim() });
    return '\x00B' + (blocks.length - 1) + '\x00';
  });
  // 2) 이미지 마커 추출 — ![id] / ![id|caption]
  s = s.replace(/!\[([^\]\n]+)\]/g, (m, raw) => {
    const parts = raw.split('|').map(x => x.trim());
    const id = parts[0];
    const caption = parts[1] || '';
    const src = images[id];
    if (!src) return m;  // ID 매칭 안 되면 마커 그대로 — 사용자가 오타 인지하도록
    blocks.push({ kind: 'image', src, alt: id, caption });
    return '\x00B' + (blocks.length - 1) + '\x00';
  });
  // 3) 나머지 텍스트 — escape + 볼드 마커
  s = fmt(s);
  // 4) placeholder 복원
  s = s.replace(/\x00B(\d+)\x00/g, (m, i) => {
    const b = blocks[+i];
    if (b.kind === 'mermaid') {
      return '<div class="mermaid" style="margin:12px 0;">' + b.code + '</div>';
    }
    if (b.kind === 'image') {
      const alt = fmt(b.alt);
      const cap = b.caption
        ? '<div style="font-size:10px;color:var(--muted);text-align:center;margin-top:4px;">' + fmt(b.caption) + '</div>'
        : '';
      return '<figure style="margin:10px 0;text-align:center;">'
           + '<img src="' + b.src + '" alt="' + alt + '" '
           + 'style="max-width:100%;border-radius:6px;border:1px solid var(--border);">'
           + cap + '</figure>';
    }
    return m;
  });
  return s;
}

// mermaid 초기화 — DOM 준비 후 1회
let _mermaidReady = false;
function initMermaid() {
  if (_mermaidReady || typeof mermaid === 'undefined') return;
  try {
    mermaid.initialize({
      startOnLoad: false,
      theme: 'default',
      securityLevel: 'loose',
    });
    _mermaidReady = true;
  } catch (e) { console.warn('mermaid init failed', e); }
}

// render() 후 미처리된 .mermaid 노드 모두 SVG 로 변환
function runMermaid() {
  if (typeof mermaid === 'undefined') return;
  initMermaid();
  try {
    const nodes = document.querySelectorAll('.mermaid:not([data-processed])');
    if (nodes.length) mermaid.run({ nodes });
  } catch (e) { console.warn('mermaid run failed', e); }
}

// ── 사이드바 메뉴는 data.menu 에서 직접 사용 ─────────
// data.menu 형식:
//   [{ id, label, items: [{ id, label, type, domain_includes? }] }]
//   type: 'profile'/'skills'/'coverletter'/'career'/'projects'/'portfolio'/'education'

function buildMenuTree() {
  const raw = Array.isArray(DATA.menu) ? DATA.menu : [];
  return raw.map(group => ({
    label: group.label || '',
    items: (group.items || []).map(it => {
      const r = it.domain_includes;
      const kws = (Array.isArray(r) ? r : (r ? [r] : []))
        .map(s => (s || '').trim()).filter(Boolean);
      return {
        name:    it.label || it.id,
        section: it.id,
        type:    it.type || 'profile',
        filter:  (it.type === 'career' && kws.length)
                  ? (c => c.domain && kws.some(k => c.domain.includes(k)))
                  : undefined,
      };
    }),
  }));
}

// 본문 section-label — 현재 활성 메뉴 항목의 표시 이름
function activeMenuName(fallback) {
  const item = findMenuItem(currentSection);
  return (item && item.name) || fallback || '';
}

function renderSidebar() {
  const nav = document.getElementById('sidebarNav');
  if (!nav) return;
  const tree = buildMenuTree();

  nav.innerHTML = tree.map(group => `
    <div class="nav-section">
      <div class="nav-label">${group.label}</div>
      ${group.items.map(it => `
        <div class="nav-item${it.section === currentSection ? ' active' : ''}"
             data-section="${it.section}">
          <div class="nav-dot"></div> ${it.name}
        </div>
      `).join('')}
    </div>
  `).join('');

  // 클릭 핸들러 재설정
  nav.querySelectorAll('.nav-item').forEach(el => {
    el.addEventListener('click', () => {
      currentSection = el.dataset.section;
      // 사용자 설정 default view 로 리셋 + 토글 active 동기화
      applyDefaultView();
      renderSidebar();
      render();
    });
  });
}

// 메뉴 → 필터 매핑 (case 라우팅에서 사용) — career_menu override 반영
function findMenuItem(section) {
  const tree = buildMenuTree();
  for (const g of tree) {
    for (const it of g.items) {
      if (it.section === section) return it;
    }
  }
  return null;
}

// 데이터 로드
function loadData() {
  document.documentElement.setAttribute('data-mode',
    (window._INLINE_DATA.mode || 'qa_mode').replace('_mode',''));
  DATA = window._INLINE_DATA;
  const tree = buildMenuTree();
  if (tree[0] && tree[0].items[0]) {
    currentSection = tree[0].items[0].section;
  }
  applyDefaultView();  // 사용자 설정 default view 로 currentView + 토글 동기화
  renderSidebarHeader();
  renderSidebar();
  renderContact();
  render();
}

// 사이드바 상단 — 이름 / 직함 / 투입가능일 (DATA.profile 에서 동적)
function renderSidebarHeader() {
  const p = DATA.profile || {};
  const nameEl  = document.getElementById('sidebarName');
  const titleEl = document.getElementById('sidebarTitle');
  const availEl = document.getElementById('sidebarAvailable');
  if (nameEl)  nameEl.textContent  = p.name  || '';
  if (titleEl) titleEl.textContent = p.title || '';
  if (availEl) availEl.textContent = p.available || '';
  // 프로필 사진: data에 photo(dataURI/URL)가 있으면 우선. 없으면 빌드시 인라인된 profile.png 유지.
  const avatarEl = document.getElementById('sidebarAvatar');
  if (avatarEl && p.photo) avatarEl.src = p.photo;
  // 브라우저 탭 제목: data.doc_title 우선, 없으면 "{이름} 이력서".
  document.title = (DATA.doc_title && DATA.doc_title.trim())
    || ((p.name && p.name !== '이름') ? p.name + ' 이력서' : '이력서');
}

// 사이드바 하단 연락처 — profile.contacts 가 있으면 그대로, 없으면 자동 추출
function renderContact() {
  const el = document.getElementById('sidebarContact');
  if (!el) return;
  const p = DATA.profile || {};
  const pf = DATA.portfolio || {};
  let items = [];
  if (Array.isArray(p.contacts) && p.contacts.length) {
    // 사용자가 프로필 탭에서 정의한 자유 항목
    items = p.contacts
      .filter(c => c && (c.label || c.text))
      .map(c => ({
        text: c.label || c.text || '',
        href: c.link || c.href || '',
      }));
  } else {
    // fallback: phone/email/portfolio 에서 자동
    if (p.phone)       items.push({ text: p.phone, href: 'tel:' + p.phone });
    if (p.email)       items.push({ text: p.email, href: 'mailto:' + p.email });
    if (pf.github_url) items.push({ text: pf.github_url.replace(/^https?:\/\//,'').replace(/\/$/,''),
                                     href: pf.github_url });
    if (Array.isArray(pf.items)) {
      const f = pf.items.find(it => it && it.link);
      if (f) items.push({ text: f.title || '포트폴리오 링크', href: f.link });
    }
  }
  if (!items.length) { el.innerHTML = ''; return; }
  el.innerHTML = items.map(it => {
    const tag = it.href ? 'a' : 'div';
    const attrs = it.href ? ` href="${it.href}" target="_blank" rel="noreferrer"` : '';
    return `<${tag} class="contact-item"${attrs}>
      <div class="contact-dot"></div><span>${it.text}</span></${tag}>`;
  }).join('');
}

// 좌측 하단 — 이력서 PDF 다운로드 (통합본: 이력서+경력기술서+자기소개서)
function downloadSummary() {
  const p = (DATA && DATA.profile) || {};
  const base = (p.export_basename || p.name || '이력서').trim();
  const filename = `${base}_이력서.pdf`;
  const encoded = encodeURIComponent(filename);
  // file:// 모드(단일 HTML 더블클릭): 같은 폴더 상대경로
  // http(s) 모드(미리보기 서버): origin 기반 절대경로
  const url = (location.protocol === 'file:')
    ? './' + encoded
    : location.origin + '/' + encoded;
  const a = document.createElement('a');
  a.href = url;
  a.download = filename;
  a.target = '_blank';
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
}

// 상단바 라벨 갱신 — 모드 메뉴 + DATA.menu_labels override
function updateTopbar() {
  const menuItem = findMenuItem(currentSection);
  const labels = DATA.menu_labels || {};
  const title = labels[currentSection] || (menuItem ? menuItem.name : '');
  const metaKey = currentSection + '__meta';
  let meta = labels[metaKey];
  if (!meta && currentSection.startsWith('career')) {
    const list = (menuItem && menuItem.filter)
      ? (DATA.career || []).filter(menuItem.filter)
      : (DATA.career || []);
    meta = `${list.length}개사`;
  }
  const tEl = document.getElementById('topbarTitle');
  const mEl = document.getElementById('topbarMeta');
  if (tEl) tEl.textContent = title;
  if (mEl) mEl.textContent = meta || '';
}

// ── 렌더러 ──────────────────────────────────
function render() {
  updateTopbar();
  const content = document.getElementById('content');
  const toggle = document.getElementById('viewToggle');

  // 메뉴 항목과 type 먼저 — id 가 무엇이든 type 으로만 분기 판단
  const menuItem = findMenuItem(currentSection);
  const type = menuItem ? menuItem.type : 'profile';

  // 토글 표시: type 이 career 또는 profile 일 때만 (id 무관)
  const showToggle = (type === 'career') || (type === 'profile');
  toggle.style.display = showToggle ? 'flex' : 'none';

  // 토글 버튼 텍스트 전환 — type 기반
  // 사주(설계도) 비활성화면 profile 타입에서 두 번째 버튼('설계도') 숨김
  const sajuEnabled = !!(DATA.features && DATA.features.saju_enabled);
  const btns = toggle.querySelectorAll('.toggle-btn');
  if (type === 'profile') {
    btns[0].textContent = '요약';
    btns[1].textContent = '설계도';
    btns[1].style.display = sajuEnabled ? '' : 'none';
    btns[2].textContent = '학력 · 병역';
    // 학력·병역 버튼 On/Off — features.education_enabled (기본 ON). Off면 버튼 숨기고 timeline 뷰는 요약으로 폴백.
    const eduOn = !(DATA.features && DATA.features.education_enabled === false);
    btns[2].style.display = eduOn ? '' : 'none';
    if (!eduOn && currentView === 'timeline') {
      currentView = 'summary';
      btns.forEach((b, i) => b.classList.toggle('active', i === 0));
    }
    // 설계도 숨겼는데 currentView 가 detail 이면 summary 로 폴백
    if (!sajuEnabled && currentView === 'detail') {
      currentView = 'summary';
      btns.forEach((b, i) => b.classList.toggle('active', i === 0));
    }
  } else {
    btns[0].textContent = '요약';
    btns[1].textContent = '상세';
    btns[1].style.display = '';   // career 모드에선 다시 표시
    btns[2].textContent = '타임라인';
  }

  // 라우팅: type 기반
  switch (type) {
    case 'profile':
      if (currentView === 'timeline') content.innerHTML = renderEducation();
      else content.innerHTML = renderProfile();
      break;
    case 'education':
      content.innerHTML = renderEducation();
      break;
    case 'coverletter':
      content.innerHTML = renderCoverLetter();
      break;
    case 'skills':
      content.innerHTML = renderSkills();
      break;
    case 'projects':
      content.innerHTML = renderProjectsWiki();
      wireProjectsWiki();
      break;
    case 'portfolio':
      content.innerHTML = renderPortfolio();
      break;
    case 'history':
      content.innerHTML = renderHistory();
      break;
    case 'career':
      // 필터 있으면 적용, 없으면 전체
      content.innerHTML = renderCareer(
        menuItem && menuItem.filter
          ? (DATA.career || []).filter(menuItem.filter)
          : (DATA.career || [])
      );
      break;
    default:
      content.innerHTML = `<p style="color:#888;padding:20px;">섹션 '${currentSection}' 미구현</p>`;
  }
  // render 후 mermaid 다이어그램 SVG 변환 (innerHTML 갱신 후 새 .mermaid 노드들)
  runMermaid();
}

