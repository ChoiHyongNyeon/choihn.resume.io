          <div>HTML 문서를 여기에 <b>드래그</b>하거나 <label class="fe-pick">파일 선택<input type="file" accept=".html,.htm,text/html" data-pfhtml="${ii}" style="display:none"></label>${it.html?` · <span style="color:var(--org)">임베드됨(${(it.html.length/1024).toFixed(0)}KB)</span> · <a href="javascript:void 0" data-act="clearpfhtml" data-ii="${ii}" style="color:var(--muted)">제거</a>`:''}</div>
        </div>
        ${it.html?`<details><summary style="font-size:11px;color:var(--muted);cursor:pointer;margin:2px 0 4px">HTML 직접 편집</summary><textarea data-sec="portfolio" data-ii="${ii}" data-field="html" style="min-height:120px;font-family:monospace;font-size:11px">${_esc(it.html)}</textarea></details>`:''}
        <input type="text" data-sec="portfolio" data-ii="${ii}" data-field="link" value="${_esc(it.link||'')}" placeholder="링크 (선택)"></div>`).join('') ; }
  function pMenu(){ const M=DATA.menu||(DATA.menu=[]);
