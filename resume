g:14px 20px;border-radius:8px;margin:12px 0;font-size:0.9em;color:#c9d1d9;border-left:3px solid #d29922;background:rgba(210,153,34,0.08);\"\u003e\n\u003cp style=\"color:#c9d1d9;margin:0;\"\u003e\u003cstrong style=\"color:#d29922;\"\u003e핵심 설계:\u003c/strong\u003e GameWorker는 반드시 \u003cstrong style=\"color:#e6edf3;\"\u003e단일 스레드\u003c/strong\u003e로 동작하여 게임 상태 동시접근을 회피합니다. BIND_SCHEDULE 주기는 시스템마다 100ms ~ 15분으로 다릅니다.\u003c/p\u003e\n\u003c/div\u003e\n\u003c/div\u003e\n\n\u003c!-- 4. 패킷 파이프라인 --\u003e\n\u003cdiv id=\"packet\" style=\"background:#161b22;border:1px solid #30363d;border-radius:12px;padding:28px 32px;margin-bottom:24px;\"\u003e\n\u003ch2 style=\"color:#e6edf3;font-size:1.4em;margin:0 0 20px;padding-bottom:12px;border-bottom:1px solid #30363d;\"\u003e4. 패킷 처리 파이프라인\u003c/h2\u003e\n\n\u003cdiv style=\"background:#1c2333;border:1px solid #30363d;border-radius:8px;padding:24px 20px;margin:12px 0;\"\u003e\n\n\u003c!-- 요청 경로 --\u003e\n\u003ch3 style=\"color:#58a6ff;font-size:1.1em;margin:8px 0 12px;\"\u003e요청 경로 (클라이언트 \u0026rarr; 서버)\u003c/h3\u003e\n\u003ctable style=\"width:100%;border-collapse:collapse;font-size:0.9em;\"\u003e\n\u003ctr\u003e\n\u003cth style=\"background:#1c2333;color:#e6edf3;padding:10px 14px;text-align:left;font-weight:600;border-bottom:2px solid #30363d;\"\u003e단계\u003c/th\u003e\n\u003cth style=\"background:#1c2333;color:#e6edf3;padding:10px 14px;text-align:left;font-weight:600;border-bottom:2px solid #30363d;\"\u003e컴포넌트\u003c/th\u003e\n\u003cth style=\"background:#1c2333;color:#e6edf3;padding:10px 14px;text-align:left;font-weight:600;border-bottom:2px solid #30363d;\"\u003e설명\u003c/th\u003e\n\u003c/tr\u003e\n\u003ctr\u003e\n\u003ctd style=\"padding:9px 14px;border-bottom:1px solid #30363d;color:#c9d1d9;\"\u003e1\u003c/td\u003e\n\u003ctd style=\"padding:9px 14px;border-bottom:1px solid #30363d;color:#58a6ff;font-weight:600;\"\u003eCSession (TLNET)\u003c/td\u003e\n\u003ctd style=\"padding:9px 14px;border-bottom:1px solid #30363d;color:#c9d1d9