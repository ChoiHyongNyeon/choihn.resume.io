    career_fields:[{id:'company',label:'타이틀',visible:true},{id:'period',label:'기간',visible:true},{id:'role',label:'담당 직무',visible:true},{id:'department',label:'서브타이틀',visible:true},{id:'summary',label:'주요 작업 내용',visible:true},{id:'bullets',label:'상세 작업 내용',visible:true},{id:'domain',label:'도메인',visible:true},{id:'platform',label:'플랫폼',visible:true}],
    profile:{name:'이름',title:'직함',objective:'',phone:'',email:'',location:'',birth:'',total_career:'',available:''},
    education:[], career:[], projects:[], history:[], skills:{}, coverletter:{sections:[]}, portfolio:{items:[],github_url:''} }; }
  function feNew(){ if(!confirm('새 빈 이력서로 시작할까요? (저장 안 한 변경은 사라집니다)'))return; const b=blankData(); Object.keys(DATA).forEach(k=>delete DATA[k]); Object.assign(DATA,b); _fileHandle=null; document.documentElement.setAttribute('data-mode','qa'); renderSidebar(); render(); feTab='profile'; feRender(); feNav(); toast('새 이력서 시작'); }
  E('edNew').onclick=feNew;
  function feExport(){
    // 현재 편집 상태(DATA)를 인라인한 단일 HTML 내보내기. 편집 UI는 data-export로 숨김.
    const clone=document.documentElement.cloneNode(true);
    clone.setAttribute('data-export','');
    const dj=JSON.stringify(DATA).replace(/</g,'\\u003c').replace(/>/g,'\\u003e').replace(/&/g,'\\u0026');
    let done=false;
    clone.querySelectorAll('script').forEach(s=>{ if(!done && s.textContent && s.textContent.trim().indexOf('window._INLINE_DATA')===0){ s.textContent='window._INLINE_DATA = '+dj+';'; done=true; } });
    const html='<!DOCTYPE html>\n'+clone.outerHTML;
    const blob=new Blob([html],{type:'text/html;charset=utf-8'});
    const a=document.createElement('a'); a.href=URL.createObjectURL(blob);
    a.download=((DATA.profile&&DATA.profile.name)||'이력서')+'_이력서.html'; a.click();
    setTimeout(()=>URL.revokeObjectURL(a.href),2000); toast('HTML 내보냄');
  }
  E('edExport').onclick=feExport;
})();
