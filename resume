  function feRender(){ const add={profile:'',projects:'+ 프로젝트',hist:'+ 연혁 항목',career:'+ 경력',cover:'+ 자소서 항목',skills:'+ 기술 카테고리',edu:'+ 학력·병역',portfolio:'+ 포트폴리오',menu:'+ 메뉴 그룹'}[feTab];
    const tabs=`<div class="fe-tabs">${TABS.map(([k,l])=>`<button class="fe-tab${k===feTab?' on':''}" data-tab="${k}">${l}</button>`).join('')}</div>`;
