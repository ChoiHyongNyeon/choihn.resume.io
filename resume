// 기술 스택 정규화 — 레거시 포맷(그룹이 배열 / item이 문자열) 호환.
// 표준형: { key: { label, items:[{name, detail, expand:[...]}] } }
function _skillGroups() {
  const sk = DATA.skills || (DATA.skills = {});
  Object.keys(sk).forEach(k => {
    let g = sk[k];
    if (Array.isArray(g)) g = sk[k] = { label: k, items: g };
    if (!g || typeof g !== 'object') g = sk[k] = { label: k, items: [] };
    if (!Array.isArray(g.items)) g.items = [];
    g.items = g.items.map(it => typeof it === 'string' ? { name: it } :
                                (it && typeof it === 'object' ? it : { name: String(it || '') }));
    if (g.label == null) g.label = k;
  });
  return sk;
}

function renderSkills() {
  // programmer 모드 + skills_progress 있으면 게이지 그리드 우선
  if ((DATA.mode || 'qa_mode') === 'programmer_mode'
      && Array.isArray(DATA.skills_progress) && DATA.skills_progress.length) {
    return renderSkillsProgress(DATA.skills_progress);
