  body.addEventListener('input',e=>{ const t=e.target, sec=t.dataset.sec; if(!sec)return; const f=t.dataset.field;
    if(sec==='profile'){ (DATA.profile||(DATA.profile={}))[f]=t.value; renderSidebarHeader(); renderContact(); }
    else if(sec==='doctitle'){ DATA.doc_title=t.value; renderSidebarHeader(); }
    else if(sec==='proj'){ const p=DATA.projects[+t.dataset.pi]; if(!p)return; if(t.dataset.si!==undefined){ const s=(p.sections||[])[+t.dataset.si]; if(!s)return; if(f==='highlight'){ if(t.checked)s.highlight=true; else delete s.highlight; t.closest('.fe-sec').classList.toggle('hi',t.checked);} else s[f]=t.value; } else { if(f==='game')p.game=t.value.split(',').map(x=>x.trim()).filter(Boolean); else p[f]=t.value; } }
    else if(sec==='career'){ const c=DATA.career[+t.dataset.ci]; if(!c)return; if(f==='bullets')c.bullets=t.value.split('\n').map(x=>x.trim()).filter(Boolean); else if(f==='domain')c.domain=t.value.split(',').map(x=>x.trim()).filter(Boolean); else c[f]=t.value; }
    else if(sec==='cover'){ const s=DATA.coverletter.sections[+t.dataset.ci]; if(!s)return; s[f]=t.value; }
    else if(sec==='skill'){ const sk=_skillGroups(); const c=sk[t.dataset.key]; if(c)c[f]=t.value; }
    else if(sec==='skillitem'){ const sk=_skillGroups(); const c=sk[t.dataset.key]; if(!c)return; const it=(c.items||[])[+t.dataset.ii]; if(!it)return; if(f==='expand')it.expand=t.value.split('\n').map(x=>x.trim()).filter(Boolean); else it[f]=t.value; }
    else if(sec==='hist'){ const h=(DATA.history||(DATA.history=[]))[+t.dataset.hi]; if(!h)return; h[f]=t.value; }
    else if(sec==='edu'){ const e=(DATA.education||(DATA.education=[]))[+t.dataset.ei]; if(!e)return; e[f]=t.value; }
    else if(sec==='edufeat'){ const ft=DATA.features||(DATA.features={}); if(f==='education_enabled')ft.education_enabled=t.checked; }
    else if(sec==='pf'){ (DATA.portfolio||(DATA.portfolio={items:[]}))[f]=t.value; }
    else if(sec==='portfolio'){ const it=(DATA.portfolio.items||[])[+t.dataset.ii]; if(!it)return; it[f]=t.value; }
    else if(sec==='menu'){ const g=DATA.menu[+t.dataset.gi]; if(!g)return; if(f==='glabel')g.label=t.value; else { const it=(g.items||[])[+t.dataset.ii]; if(!it)return; it[f]=t.value; if(f==='type'&&!it.id)it.id='sec-'+Date.now(); } renderSidebar(); }
    reb(); });
  body.addEventListener('click',e=>{ const tb=e.target.closest('[data-tab]'); if(tb){ feTab=tb.dataset.tab; feRender(); feNav(); return; }
    const bb=e.target.closest('[data-act]'); if(!bb)return; const act=bb.dataset.act;
    if(act==='delproj'){ if(!confirm('삭제할까요?'))return; DATA.projects.splice(+bb.dataset.pi,1); }
    else if(act==='addsec'){ const p=DATA.projects[+bb.dataset.pi]; (p.sections||(p.sections=[])).push({title:'',body:''}); }
    else if(act==='delsec'){ DATA.projects[+bb.dataset.pi].sections.splice(+bb.dataset.si,1); }
    else if(act==='delcareer'){ if(!confirm('삭제할까요?'))return; DATA.career.splice(+bb.dataset.ci,1); }
    else if(act==='delcover'){ DATA.coverletter.sections.splice(+bb.dataset.ci,1); }
    else if(act==='delskill'){ delete DATA.skills[bb.dataset.key]; }
    else if(act==='addskillitem'){ const c=_skillGroups()[bb.dataset.key]; if(c)(c.items||(c.items=[])).push({name:'',detail:'',expand:[]}); }
    else if(act==='delskillitem'){ const c=_skillGroups()[bb.dataset.key]; if(c&&c.items)c.items.splice(+bb.dataset.ii,1); }
    else if(act==='deledu'){ if(!confirm('삭제할까요?'))return; (DATA.education||[]).splice(+bb.dataset.ei,1); }
    else if(act==='delhist'){ if(!confirm('삭제할까요?'))return; (DATA.history||[]).splice(+bb.dataset.hi,1); }
    else if(act==='histup'||act==='histdown'){ const H=DATA.history||[]; const hi=+bb.dataset.hi, j=hi+(act==='histup'?-1:1); if(j>=0&&j<H.length){ [H[hi],H[j]]=[H[j],H[hi]]; } }
    else if(act==='delpf'){ DATA.portfolio.items.splice(+bb.dataset.ii,1); }
    else if(act==='clearpfimg'){ const it=(DATA.portfolio.items||[])[+bb.dataset.ii]; if(it)it.image=''; }
    else if(act==='clearpfhtml'){ const it=(DATA.portfolio.items||[])[+bb.dataset.ii]; if(it)it.html=''; }
    else if(act==='clearprofimg'){ if(DATA.profile)DATA.profile.photo=''; renderSidebarHeader(); }
    else if(act==='delmenuitem'){ DATA.menu[+bb.dataset.gi].items.splice(+bb.dataset.ii,1); renderSidebar(); }
    else if(act==='delgroup'){ if(!confirm('이 메뉴 그룹을 삭제할까요?'))return; DATA.menu.splice(+bb.dataset.gi,1); renderSidebar(); }
    else if(act==='addmenuitem'){ const g=DATA.menu[+bb.dataset.gi]; (g.items||(g.items=[])).push({id:'sec-'+Date.now(),label:'새 메뉴',type:'profile'}); renderSidebar(); }
    else if(act==='grpup'||act==='grpdown'){ const gi=+bb.dataset.gi, j=gi+(act==='grpup'?-1:1); if(j>=0&&j<DATA.menu.length){ const m=DATA.menu; [m[gi],m[j]]=[m[j],m[gi]]; renderSidebar(); } }
    else if(act==='itemup'||act==='itemdown'){ const g=DATA.menu[+bb.dataset.gi]; const ii=+bb.dataset.ii, j=ii+(act==='itemup'?-1:1); if(g&&g.items&&j>=0&&j<g.items.length){ [g.items[ii],g.items[j]]=[g.items[j],g.items[ii]]; renderSidebar(); } }
    feRender(); render(); });
  // 이미지 파일 → dataURI (필요 시 다운스케일로 용량 억제). 투명도 보존 위해 png는 png, 그 외 jpeg.
  function fileToImageDataURI(file){ return new Promise((resolve,reject)=>{
    const fr=new FileReader();
    fr.onerror=()=>reject(new Error('읽기 실패'));
    fr.onload=()=>{ const raw=fr.result; const img=new Image();
      img.onerror=()=>reject(new Error('이미지 디코드 실패'));
      img.onload=()=>{ const MAX=1600, w=img.naturalWidth, h=img.naturalHeight, big=Math.max(w,h);
        if(big<=MAX && raw.length<=900000){ resolve(raw); return; }   // 작으면 원본 그대로
        const sc=big>MAX?MAX/big:1, cw=Math.round(w*sc), ch=Math.round(h*sc);
        const cv=document.createElement('canvas'); cv.width=cw; cv.height=ch;
        const cx=cv.getContext('2d'); cx.drawImage(img,0,0,cw,ch);
        const isPng=/^data:image\/png/i.test(raw);
        resolve(cv.toDataURL(isPng?'image/png':'image/jpeg', isPng?undefined:0.9)); };
      img.src=raw; };
    fr.readAsDataURL(file); }); }
  function applyPfImage(ii, file){ const it=(DATA.portfolio&&DATA.portfolio.items||[])[ii]; if(!it)return;
    if(!file||!/^image\//.test(file.type)){ toast('이미지 파일만 가능합니다'); return; }
    fileToImageDataURI(file).then(uri=>{ it.image=uri; feRender(); render(); toast('이미지 적용됨'); })
      .catch(e=>{ toast('이미지 처리 실패: '+e.message); }); }
  // HTML 문서 파일 → it.html (텍스트로 인라인, 렌더 시 DOMPurify sanitize)
  function fileToText(file){ return new Promise((resolve,reject)=>{ const fr=new FileReader(); fr.onerror=()=>reject(new Error('읽기 실패')); fr.onload=()=>resolve(fr.result); fr.readAsText(file); }); }
  function applyPfHtml(ii, file){ const it=(DATA.portfolio&&DATA.portfolio.items||[])[ii]; if(!it)return;
    if(!file){ return; } if(!/\.html?$/i.test(file.name) && !/html/.test(file.type)){ toast('HTML 파일만 가능합니다'); return; }
    fileToText(file).then(txt=>{ it.html=txt; feRender(); render(); toast('HTML 임베드됨'); })
      .catch(e=>{ toast('HTML 처리 실패: '+e.message); }); }
  // 프로필 사진 → DATA.profile.photo (dataURI). 이미지 헬퍼 재사용(자동 다운스케일).
  function applyProfilePhoto(file){ const p=DATA.profile||(DATA.profile={});
    if(!file||!/^image\//.test(file.type)){ toast('이미지 파일만 가능합니다'); return; }
    fileToImageDataURI(file).then(uri=>{ p.photo=uri; renderSidebarHeader(); feRender(); render(); toast('프로필 사진 적용됨'); })
      .catch(e=>{ toast('이미지 처리 실패: '+e.message); }); }
  body.addEventListener('change',e=>{ const t=e.target; if(!t.dataset)return; const f=t.files&&t.files[0]; if(!f)return;
    if(t.dataset.pfimg!==undefined)applyPfImage(+t.dataset.pfimg, f);
    else if(t.dataset.pfhtml!==undefined)applyPfHtml(+t.dataset.pfhtml, f);
    else if(t.dataset.profimg!==undefined)applyProfilePhoto(f); });
  body.addEventListener('dragover',e=>{ const z=e.target.closest&&e.target.closest('.fe-drop[data-drop]'); if(z){ e.preventDefault(); e.dataTransfer.dropEffect='copy'; z.classList.add('over'); } });
  body.addEventListener('dragleave',e=>{ const z=e.target.closest&&e.target.closest('.fe-drop[data-drop]'); if(z&&!z.contains(e.relatedTarget))z.classList.remove('over'); });
  body.addEventListener('drop',e=>{ const z=e.target.closest&&e.target.closest('.fe-drop[data-drop]'); if(!z)return; e.preventDefault(); z.classList.remove('over');
    const dt=e.dataTransfer, kind=z.dataset.drop, ii=+z.dataset.ii, file=dt.files&&dt.files[0];
    if(kind==='profimg'){ if(file)applyProfilePhoto(file); else { const u=dt.getData&&(dt.getData('text/uri-list')||dt.getData('text/plain')); if(u){ (DATA.profile||(DATA.profile={})).photo=u.trim(); renderSidebarHeader(); feRender(); render(); toast('프로필 사진 URL 적용됨'); } } return; }
    if(kind==='pfhtml'){ if(file)applyPfHtml(ii, file); return; }
    if(file){ applyPfImage(ii, file); return; }
    const url=dt.getData&&dt.getData('text/uri-list')||dt.getData&&dt.getData('text/plain'); // 웹 이미지 드래그(URL)
    if(url){ const it=(DATA.portfolio.items||[])[ii]; if(it){ it.image=url.trim(); feRender(); render(); toast('이미지 URL 적용됨'); } } });
  function openEd(){ feRender(); ed.classList.add('open'); E('edScrim').classList.add('open'); feNav(); }
