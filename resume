        <div class="fe-drop" data-drop="pf" data-ii="${ii}">
          ${it.image?`<img class="fe-thumb" src="${_esc(it.image)}" alt="">`:''}
          <div>이미지를 여기에 <b>드래그</b>하거나 <label class="fe-pick">파일 선택<input type="file" accept="image/*" data-pfimg="${ii}" style="display:none"></label>${it.image?` · <a href="javascript:void 0" data-act="clearpfimg" data-ii="${ii}" style="color:var(--muted)">이미지 제거</a>`:''}</div>
        </div>
        <div class="fe-imgrow"><input type="text" data-sec="portfolio" data-ii="${ii}" data-field="image" value="${_esc(it.image||'')}" placeholder="이미지 URL 또는 data:image/...;base64,..."></div>
