  return Object.values(sk).map(group => `
    <div class="card skill-group">
      <div class="skill-group-title">${group.label}</div>
      ${group.items.map((item, idx) => {
        const hasExpand = item.expand && item.expand.length > 0;
        const expandId = `expand-${group.label}-${idx}`;
        return `
        <div class="skill-row ${hasExpand ? 'has-expand' : ''}" ${hasExpand ? `onclick="toggleExpand('${expandId}')"` : ''}>
          <div class="skill-name">
