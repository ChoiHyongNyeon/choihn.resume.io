  async function feOpen(){ try{ if(window.showOpenFilePicker){ const [h]=await window.showOpenFilePicker({types:[{description:'data.json',accept:{'application/json':['.json']}}]}); _fileHandle=h; const f=await h.getFile(); const nd=JSON.parse(await f.text()); Object.keys(DATA).forEach(k=>delete DATA[k]); Object.assign(DATA,nd); document.documentElement.setAttribute('data-mode',(DATA.mode||'qa_mode').replace('_mode','')); renderSidebar(); render(); feRender(); toast('열기: '+h.name); } else { alert('직접 열기는 크롬/엣지에서 지원됩니다.'); } }catch(e){ if(e&&e.name!=='AbortError')alert('열기 실패: '+e.message); } }
  async function feSave(){ const json=JSON.stringify(DATA,null,2); try{ if(_fileHandle&&_fileHandle.createWritable){ const w=await _fileHandle.createWritable(); await w.write(json); await w.close(); toast('저장됨: '+_fileHandle.name); return; } if(window.showSaveFilePicker){ _fileHandle=await window.showSaveFilePicker({suggestedName:((DATA.profile&&DATA.profile.name)||'data')+'.json',types:[{description:'data.json',accept:{'application/json':['.json']}}]}); const w=await _fileHandle.createWritable(); await w.write(json); await w.close(); toast('저장됨: '+_fileHandle.name); return; } }catch(e){ if(e&&e.name==='AbortError')return; } const blob=new Blob([json],{type:'application/json'}); const a=document.createElement('a'); a.href=URL.createObjectURL(blob); a.download=((DATA.profile&&DATA.profile.name)||'data')+'.json'; a.click(); setTimeout(()=>URL.revokeObjectURL(a.href),2000); }
