    const ord=(act,a,b,dis,title)=>`<button class="fe-ord" data-act="${act}" ${Object.entries(b).map(([k,v])=>`data-${k}="${v}"`).join(' ')} ${dis?'disabled':''} title="${title}">${a}</button>`;
    return `<div style="font-size:11px;color:var(--muted);margin:0 0 8px">메뉴 이름·종류를 바꾸면 좌측 사이드바에 즉시 반영됩니다. ↑↓로 순서를 바꿀 수 있습니다.</div>`
      + M.map((g,gi)=>`<div class="fe-proj"><div class="fe-h"><b>그룹</b><input type="text" data-sec="menu" data-gi="${gi}" data-field="glabel" value="${_esc(g.label||'')}" placeholder="그룹 이름">${ord('grpup','↑',{gi},gi===0,'그룹 위로')}${ord('grpdown','↓',{gi},gi===M.length-1,'그룹 아래로')}<button class="fe-del" data-act="delgroup" data-gi="${gi}">✕</button></div>
        ${(g.items||[]).map((it,ii)=>`<div class="fe-srow"><input type="text" data-sec="menu" data-gi="${gi}" data-ii="${ii}" data-field="label" value="${_esc(it.label||'')}" placeholder="메뉴 이름">
          <select data-sec="menu" data-gi="${gi}" data-ii="${ii}" data-field="type">${opt(it.type||'profile')}</select>
          ${ord('itemup','↑',{gi,ii},ii===0,'항목 위로')}${ord('itemdown','↓',{gi,ii},ii===(g.items.length-1),'항목 아래로')}
          <button class="fe-del" data-act="delmenuitem" data-gi="${gi}" data-ii="${ii}">삭제</button></div>`).join('')}
