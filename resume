        <textarea data-sec="skillitem" data-key="${_esc(k)}" data-ii="${ii}" data-field="expand" placeholder="클릭 시 펼쳐질 상세 (한 줄 = 한 항목, 비우면 클릭 비활성)">${_esc((it.expand||[]).join('\n'))}</textarea></div>`).join('');
      return `<div class="fe-proj"><div class="fe-h"><input type="text" data-sec="skill" data-key="${_esc(k)}" data-field="label" value="${_esc(c.label||k)}" placeholder="카테고리명"><button class="fe-del" data-act="delskill" data-key="${_esc(k)}">✕</button></div>${items}<button class="fe-addsec" data-act="addskillitem" data-key="${_esc(k)}">+ 기술 항목</button></div>`;}).join('')||empty('보유 기술'); }
  function pEdu(){ const ED=DATA.education||(DATA.education=[]);
    const on=!(DATA.features&&DATA.features.education_enabled===false);
    const head=`<div class="fe-proj"><label class="fe-lbl" style="font-size:13px"><input type="checkbox" data-sec="edufeat" data-field="education_enabled" ${on?'checked':''}> 이력서에 “학력 · 병역” 표시</label><div style="font-size:11px;color:var(--muted);margin-top:4px">끄면 프로필 화면의 “학력 · 병역” 버튼이 숨겨집니다. 병역은 학교/구분란에 “병역” 등으로 항목을 추가해 적으세요.</div></div>`;
    const items=ED.map((e,ei)=>`<div class="fe-proj"><div class="fe-h"><b>#${ei+1}</b><input type="text" data-sec="edu" data-ei="${ei}" data-field="school" value="${_esc(e.school||'')}" placeholder="학교 / 구분 (예: ○○대학교, 병역)"><button class="fe-del" data-act="deledu" data-ei="${ei}">✕</button></div>
      <div class="fe-grid"><input type="text" data-sec="edu" data-ei="${ei}" data-field="major" value="${_esc(e.major||'')}" placeholder="전공 / 구분"><input type="text" data-sec="edu" data-ei="${ei}" data-field="period" value="${_esc(e.period||'')}" placeholder="기간"><input type="text" data-sec="edu" data-ei="${ei}" data-field="gpa" value="${_esc(e.gpa||'')}" placeholder="학점 (선택)"></div>
      <label class="fe-fl"><span>비고 (선택)</span><textarea data-sec="edu" data-ei="${ei}" data-field="note">${_esc(e.note||'')}</textarea></label></div>`).join('')||empty('학력·병역');
    return head+items; }
  function pPortfolio(){ const pf=DATA.portfolio||(DATA.portfolio={items:[]}); const I=pf.items||(pf.items=[]);
    return `<div class="fe-proj"><label class="fe-fl"><span>GitHub URL (선택)</span>${fi('pf','github_url',pf.github_url,'https://...')}</label></div>`
