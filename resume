// ── 프로젝트 위키 (셸 내 네이티브 렌더) ──────────────────────────
function _esc(s){return String(s==null?'':s).replace(/[&<>"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));}
function _md(t){ if(t==null) return ''; const s=String(t); if(!s.trim()) return '';
  let raw = window.marked ? marked.parse(s) : _esc(s);
  return window.DOMPurify ? DOMPurify.sanitize(raw) : raw; }
function _mdInline(t){ return _md(t).replace(/^<p>/,'').replace(/<\/p>\s*$/,''); }
function _pwSlug(s){return String(s||'').trim().replace(/\s+/g,'-').replace(/[^\w가-힣\-]/g,'').toLowerCase();}

function renderProjectsWiki(){
  const projects = DATA.projects || [];
  const n = projects.length;
  const pid = p => 'pw-'+_pwSlug(p.id||p.name);

  const chips = p => {
    const out=[]; const games=p.game||[];
    if(games.length) games.forEach((g,i)=>out.push(`<span class="pw-chip${i===0?' key':''}">${_esc(g)}</span>`));
    else if(p.status) out.push(`<span class="pw-chip key">${_esc(p.status)}</span>`);   // 구 데이터 폴백
    if(p.role) out.push(`<span class="pw-chip">${_esc(p.role)}</span>`);
    if(p.period) out.push(`<span class="pw-chip period">${_esc(p.period)}</span>`);
    return out.length?`<div class="pw-chips">${out.join('')}</div>`:'';
  };
  const meta = p => {
    const m=[];
    if(p.team&&(p.team.total||p.team.main)) m.push(`팀 ${_esc(String(p.team.total||'?'))}명${p.team.main?`(메인 ${_esc(String(p.team.main))})`:''}`);
    if(p.appeal) m.push(`<span class="pw-appeal">어필: ${_esc(p.appeal)}</span>`);
    return m.length?`<div class="pw-meta">${m.join('  ·  ')}</div>`:'';
  };
  const box = (title, inner, hi) =>
    `<div class="pw-sec${hi?' hi':''}">`
    +(title?`<div class="pw-sec-h">${_esc(title)}</div>`:'')
    +`<div class="pw-md">${inner}</div></div>`;
  const bulletsFb = bullets => {   // [브래킷]→박스 폴백 (구 데이터)
    if(!bullets||!bullets.length) return '';
    const groups=[]; let cur=null;
    bullets.forEach(b=>{ const t=String(b).trim(); const mm=t.match(/^\[(.+)\]$/);
      if(mm){ cur={title:mm[1],items:[]}; groups.push(cur); }
      else { if(!cur){ cur={title:'',items:[]}; groups.push(cur); } cur.items.push(t); } });
    return groups.map(g=>box(g.title,
      `<ul class="pw-ul">${g.items.map(it=>`<li>${_mdInline(it)}</li>`).join('')}</ul>`,
      /성과|결과/.test(g.title))).join('');
  };
  const secs = p => {
    if(Array.isArray(p.sections)&&p.sections.length){    // 신 스키마 → 박스 (group=서브프로젝트 헤더)
      let html='', lastG=null;
      p.sections.forEach(s=>{
        const g=s.group||'';
        if(g && g!==lastG){ html+=`<div class="pw-group">${_esc(g)}</div>`; }
        lastG=g;
        html += box(s.title||'', _md(s.body||''), s.highlight===true);
      });
      return html;
    }
    return bulletsFb(p.bullets);
  };
  const att = p => {
    if(!Array.isArray(p.attachments)||!p.attachments.length) return '';
    return `<div class="pw-att">`+p.attachments.map(a=> a&&a.url
      ? `<a href="${_esc(a.url)}" target="_blank" rel="noopener">↗ ${_esc(a.label||a.url)}</a>`
      : `<span>↗ ${_esc((a&&a.label)||'')}</span>`).join('')+`</div>`;
  };

  const toc = projects.map((p,i)=>
    `<li><a href="#${pid(p)}" data-target="${pid(p)}" title="${_esc(p.name||'')}"><span class="pw-n">${i+1}.</span><span class="pw-tname">${_esc(p.name||'')}</span></a></li>`
  ).join('');

  const items = projects.map((p,i)=>
    `<section class="pw-proj" id="${pid(p)}">`
    +`<h3 class="pw-name"><span class="pw-num">${i+1}.</span> ${_esc(p.name||'')}</h3>`
    +chips(p)+meta(p)
    +(p.summary?`<div class="pw-md pw-summary">${_md(p.summary)}</div>`
              :(p.desc?`<div class="pw-md pw-summary">${_md(p.desc)}</div>`:''))
    +secs(p)+att(p)
    +`</section>`
  ).join('');

  const sub = [(DATA.profile&&DATA.profile.title)||'', `주요 개발 및 운영 경험 ${n}건`].filter(Boolean).join(' · ');
  return `
    <div class="pw">
      <div class="pw-bar"><span class="section-label" style="margin:0">${activeMenuName('프로젝트')}</span><button class="pw-toggle" id="pwToggle">◧ 목차 숨기기</button></div>
      <div class="pw-wrap" id="pwWrap">
        <aside class="pw-toc" id="pwToc">
          <div class="pw-toc-head">프로젝트 목차 <span class="pw-cnt">${n}</span></div>
          <ol class="pw-toc-list">${toc}</ol>
        </aside>
        <div class="pw-doc">
          <div class="pw-doc-sub">${_esc(sub)}</div>
          ${items}
        </div>
      </div>
    </div>`;
}

function wireProjectsWiki(){
  const toggle=document.getElementById('pwToggle');
  if(toggle) toggle.onclick=function(){
    const w=document.getElementById('pwWrap');
    const off=w.classList.toggle('pw-toc-off');
    this.textContent = off?'☰ 목차 보기':'◧ 목차 숨기기';
  };
  const cont=document.getElementById('content');
  const heads=[...document.querySelectorAll('.pw-proj')];
  const links=[...document.querySelectorAll('.pw-toc-list a')];
  const setActive=id=>links.forEach(l=>l.classList.toggle('active', l.dataset.target===id));
  document.querySelectorAll('.pw-toc-list a').forEach(a=>{
    a.addEventListener('click',e=>{ e.preventDefault();
      const t=document.getElementById(a.dataset.target);
      if(t){ setActive(a.dataset.target);   // 스크롤 여유가 부족해도 즉시 하이라이트 피드백
             t.scrollIntoView({behavior:'smooth',block:'start'}); } });
  });
  if(cont && heads.length){
    if(cont._pwspy) cont.removeEventListener('scroll',cont._pwspy);
    const spy=()=>{ let cur=heads[0];
      for(const h of heads){ if(h.getBoundingClientRect().top<150) cur=h; }
      // 바닥에 닿으면 마지막 섹션 강제 활성 (짧은 말단 섹션 보정)
      if(cont.scrollTop+cont.clientHeight >= cont.scrollHeight-4) cur=heads[heads.length-1];
      setActive(cur.id); };
    cont._pwspy=spy; cont.addEventListener('scroll',spy,{passive:true}); spy();
  }
}

