<!DOCTYPE html>
<html lang="ko" data-mode="programmer" data-export=""><head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>서버 프로그래머 최형년 이력서</title>
<script src="https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.min.js"></script>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  /* 기본 (qa_mode) — html 태그에 data-mode 속성 없을 때도 적용 */
  :root, :root[data-mode="qa"] {
    --bg:       #FAF8F4;
    --sidebar:  #F0EBE1;
    --border:   #D8CFC0;
    --white:    #FFFFFF;
    --org:      #C45000;
    --org-lt:   #FFF4EE;
    --blk:      #2C2C2A;
    --gray:     #5F5E5A;
    --muted:    #888780;
    --hint:     #B4B2A9;
    --hover:    #E8E0D4;
    --card-hi:  #FFF8F3;
    --photo-radius: 50%;
    --sidebar-text: var(--blk);
    --sidebar-label: var(--muted);
  }

  /* programmer_mode — 다크 사이드바 + 흰 본문 + 그린 강조 */
  :root[data-mode="programmer"] {
    --bg:       #FFFFFF;
    --sidebar:  #1a2033;
    --border:   #E5E5E5;
    --white:    #FFFFFF;
    --org:      #4a9d7f;
    --org-lt:   #E8F5EF;
    --blk:      #2C2C2A;
    --gray:     #5F5E5A;
    --muted:    #888780;
    --hint:     #6B7280;
    --hover:    rgba(78,157,127,0.12);
    --card-hi:  #F8FAF9;
  }

  /* ── programmer 모드 디테일 (목업 v2 일치) ── */

  /* 사이드바 헤더 — 가로 배치 → 세로 정렬, 아바타 둥근 사각형 + 그린 보더 */
  :root[data-mode="programmer"] .sidebar-header {
    flex-direction: column !important;
    align-items: center !important;
    padding: 28px 20px 20px !important;
    border-bottom: 0.5px solid #2a3550;
    gap: 0 !important;
  }
  :root[data-mode="programmer"] .sidebar-header img {
    width: 80px !important;
    height: 80px !important;
    border-radius: 12px !important;
    border: 2px solid #4a9d7f;
    margin: 0 auto 12px !important;
    object-fit: cover;
  }
  :root[data-mode="programmer"] .sidebar-name {
    text-align: center;
    color: #e8edf5 !important;
    font-size: 15px;
  }
  :root[data-mode="programmer"] .sidebar-title {
    text-align: center;
    color: #4a9d7f !important;
    font-size: 11px;
  }

  /* 메뉴 */
  :root[data-mode="programmer"] .nav-item       { color: #8899bb; }
  :root[data-mode="programmer"] .nav-item.active {
    color: #7ecdb0;
    background: rgba(78, 157, 127, 0.12);
    border-left: 2px solid #4a9d7f;
  }
  :root[data-mode="programmer"] .nav-item:hover { background: rgba(78,157,127,0.08); }
  :root[data-mode="programmer"] .nav-label      { color: #4a5a7a; }
  :root[data-mode="programmer"] .nav-dot        { background: currentColor; }

  /* 토글 (요약/상세/타임라인) — 외부 박스 투명 + pill 형태 */
  :root[data-mode="programmer"] .view-toggle {
    background: transparent !important;
    padding: 0 !important;
    gap: 4px !important;
    border-radius: 0 !important;
  }
  :root[data-mode="programmer"] .toggle-btn {
    color: var(--gray);
    border: 0.5px solid var(--border) !important;
    background: transparent !important;
    border-radius: 20px !important;
    padding: 4px 12px !important;
  }
  :root[data-mode="programmer"] .toggle-btn:hover {
    color: var(--blk);
    background: rgba(78,157,127,0.06) !important;
  }
  :root[data-mode="programmer"] .toggle-btn.active {
    background: #4a9d7f !important;
    color: #ffffff !important;
    border-color: #4a9d7f !important;
  }

  /* 태그 칩 — 옅은 그린 배경 + 그린 텍스트 + 보더 */
  :root[data-mode="programmer"] .tag {
    background: rgba(78,157,127,0.10) !important;
    color: #2a7a5a !important;
    border: 0.5px solid rgba(78,157,127,0.3) !important;
    border-radius: 10px !important;
  }

  /* 카드 — 흰 배경 + 옅은 보더 */
  :root[data-mode="programmer"] .card {
    background: #ffffff !important;
    border: 0.5px solid var(--border) !important;
  }

  /* 기간 / 강조 텍스트 그린 */
  :root[data-mode="programmer"] .card-period,
  :root[data-mode="programmer"] .org-text { color: #4a9d7f !important; }

  /* programmer 모드: 본문(흰 배경) 안에서 인라인 background:var(--sidebar) 가 박힌
     사주 원국/스트라이프 행 등을 옅은 회색으로 덮어쓰고 텍스트 색도 보정. */
  :root[data-mode="programmer"] .main tr[style*="--sidebar"],
  :root[data-mode="programmer"] .main div[style*="--sidebar"] {
    background: #f4f6fa !important;
  }
  :root[data-mode="programmer"] .main tr[style*="--sidebar"] td,
  :root[data-mode="programmer"] .main div[style*="--sidebar"] {
    color: var(--gray) !important;
  }

  /* 사이드바 하단 인쇄/다운로드 버튼 — 어둠 위 옅은 텍스트 */
  :root[data-mode="programmer"] .print-btn {
    color: #8899bb !important;
    border: 0.5px solid #2a3550 !important;
    background: transparent !important;
  }
  :root[data-mode="programmer"] .print-btn:hover {
    color: #7ecdb0 !important;
    background: rgba(78,157,127,0.08) !important;
  }

  /* 사이드바 연락처 블록 — 양 모드 공통 + 모드별 색 보정 */
  .sidebar-contact {
    padding: 14px 18px;
    border-top: 0.5px solid var(--border);
  }
  .contact-item {
    font-size: 11px;
    color: var(--gray);
    margin-bottom: 6px;
    display: flex;
    align-items: center;
    gap: 6px;
    text-decoration: none;
    cursor: default;
  }
  a.contact-item { cursor: pointer; }
  a.contact-item:hover { color: var(--org); }
  .contact-dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--org);
    flex-shrink: 0;
  }
  /* programmer 모드: 다크 사이드바에 맞춰 텍스트 옅게 */
  :root[data-mode="programmer"] .sidebar-contact {
    border-top-color: #2a3550;
  }
  :root[data-mode="programmer"] .contact-item { color: #5a7a9a; }
  :root[data-mode="programmer"] a.contact-item:hover { color: #7ecdb0; }
  :root[data-mode="programmer"] .contact-dot { background: #4a9d7f; }

  /* programmer 모드 — 기술 스택 게이지 카드 그리드 */
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 10px;
    margin-top: 8px;
  }
  .skill-card {
    background: var(--card-hi);
    border: 0.5px solid var(--border);
    border-radius: 6px;
    padding: 12px;
  }
  .skill-name { font-size: 12px; font-weight: 500; color: var(--blk); margin-bottom: 6px; }
  .skill-bar-bg { height: 4px; background: var(--border); border-radius: 2px; overflow: hidden; }
  .skill-bar { height: 4px; background: var(--org); border-radius: 2px; transition: width .3s; }
  .skill-level { font-size: 10px; color: var(--gray); margin-top: 4px; }

  html, body {
    height: 100%;
    background: var(--bg);
    font-family: "Pretendard","Noto Sans KR",-apple-system,BlinkMacSystemFont,"Apple SD Gothic Neo","Malgun Gothic","맑은 고딕","Segoe UI",sans-serif;
    color: var(--blk);
    font-size: 13px;
    line-height: 1.6;
  }

  /* ── 레이아웃 ── */
  .app {
    display: flex;
    height: 100vh;
    overflow: hidden;
  }

  /* ── 사이드바 ── */
  .sidebar {
    width: 220px;
    min-width: 220px;
    background: var(--sidebar);
    border-right: 3px solid var(--org);
    display: flex;
    flex-direction: column;
    overflow-y: auto;
  }

  .sidebar-header {
    padding: 22px 18px 16px;
    border-bottom: 1px solid var(--border);
  }

  .sidebar-name {
    font-size: 16px;
    font-weight: 700;
    color: var(--blk);
    letter-spacing: 0.3px;
  }

  .sidebar-title {
    font-size: 11px;
    color: var(--muted);
    margin-top: 3px;
  }

  /* 네비게이션 */
  .nav-section { padding: 12px 12px 4px; }

  .nav-label {
    font-size: 10px;
    font-weight: 600;
    color: var(--hint);
    letter-spacing: 0.8px;
    text-transform: uppercase;
    padding: 0 6px;
    margin-bottom: 4px;
  }

  .nav-item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 7px 8px;
    border-radius: 6px;
    font-size: 12px;
    color: var(--gray);
    cursor: pointer;
    transition: background 0.12s;
    user-select: none;
  }

  .nav-item:hover { background: var(--hover); }

  .nav-item.active {
    background: var(--blk);
    color: var(--bg);
  }

  .nav-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: currentColor;
    opacity: 0.4;
    flex-shrink: 0;
  }

  .nav-item.active .nav-dot {
    opacity: 1;
    background: var(--org);
  }

  /* 하단 버튼 */
  .sidebar-footer {
    margin-top: auto;
    padding: 12px;
    border-top: 1px solid var(--border);
  }

  .print-btn {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding: 8px;
    border-radius: 6px;
    border: 1px solid var(--border);
    background: var(--bg);
    font-size: 12px;
    color: var(--gray);
    cursor: pointer;
    font-family: inherit;
    transition: background 0.12s;
  }

  .print-btn:hover { background: var(--hover); }

  /* ── 메인 ── */
  .main {
    flex: 1;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    background: var(--bg);
  }

  /* 상단바 */
  .topbar {
    padding: 16px 24px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: var(--bg);
    flex-shrink: 0;
  }

  .topbar-title { font-size: 15px; font-weight: 600; color: var(--blk); }
  .topbar-meta { font-size: 11px; color: var(--hint); margin-top: 2px; }

  .view-toggle {
    display: flex;
    gap: 3px;
    background: var(--sidebar);
    border-radius: 6px;
    padding: 3px;
  }

  .toggle-btn {
    font-size: 11px;
    padding: 4px 12px;
    border-radius: 4px;
    border: none;
    background: transparent;
    color: var(--muted);
    cursor: pointer;
    font-family: inherit;
    transition: all 0.12s;
  }

  .toggle-btn:hover { color: var(--blk); }

  .toggle-btn.active {
    background: var(--blk);
    color: var(--bg);
  }

  /* 콘텐츠 영역 */
  .content {
    flex: 1;
    overflow-y: auto;
    padding: 24px;
  }

  /* 섹션 레이블 */
  .section-label {
    font-size: 10px;
    font-weight: 600;
    color: var(--hint);
    letter-spacing: 0.8px;
    text-transform: uppercase;
    margin-bottom: 10px;
    margin-top: 20px;
  }

  .section-label:first-child { margin-top: 0; }

  /* 카드 */
  .card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 16px 18px;
    margin-bottom: 10px;
  }

  .card.highlight {
    background: var(--card-hi);
    border-color: #E8C4A8;
    border-left: 3px solid var(--org);
  }

  .card-head {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 4px;
    margin-bottom: 3px;
  }

  .card-co {
    font-size: 14px;
    font-weight: 600;
    color: var(--blk);
  }

  .card-period {
    font-size: 11px;
    color: var(--hint);
  }

  .badge {
    display: inline-block;
    font-size: 10px;
    padding: 2px 7px;
    border-radius: 10px;
    background: var(--org-lt);
    color: var(--org);
    font-weight: 600;
  }

  .card-project {
    font-size: 11px;
    color: var(--muted);
    margin-bottom: 4px;
  }

  .card-role {
    font-size: 12px;
    color: var(--org);
    font-weight: 500;
    margin-bottom: 10px;
  }

  .card-summary {
    font-size: 12px;
    color: var(--gray);
    margin-bottom: 10px;
    font-style: italic;
    border-left: 2px solid var(--border);
    padding-left: 10px;
  }

  .bullets {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .bullets li {
    font-size: 12px;
    color: var(--gray);
    display: flex;
    gap: 8px;
    align-items: flex-start;
  }

  .bullets li::before {
    content: '';
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--org);
    margin-top: 6px;
    flex-shrink: 0;
  }

  /* 수치 카드 (상세 뷰용) */
  .stats-row {
    display: flex;
    gap: 8px;
    margin-top: 12px;
    flex-wrap: wrap;
  }

  .stat-item {
    background: var(--sidebar);
    border-radius: 6px;
    padding: 8px 12px;
    min-width: 90px;
  }

  .stat-val {
    font-size: 15px;
    font-weight: 700;
    color: var(--org);
  }

  .stat-lbl {
    font-size: 10px;
    color: var(--muted);
    margin-top: 1px;
  }

  /* 스킬 테이블 */
  .skill-group { margin-bottom: 16px; }

  .skill-group-title {
    font-size: 12px;
    font-weight: 600;
    color: var(--blk);
    margin-bottom: 8px;
    padding-bottom: 4px;
    border-bottom: 1px solid var(--border);
  }

  .skill-row {
    display: flex;
    gap: 12px;
    padding: 6px 0;
    border-bottom: 1px solid #F0EBE1;
    font-size: 12px;
  }

  .skill-name {
    min-width: 130px;
    font-weight: 500;
    color: var(--org);
  }

  .skill-detail { color: var(--gray); }

  .has-expand { cursor: pointer; }
  .has-expand:hover { background: #F7F3ED; border-radius: 4px; }
  .expand-arrow { font-size: 10px; color: var(--org); margin-left: 5px; }
  .skill-expand { display: none; padding: 6px 0 6px 14px; border-bottom: 1px solid #F0EBE1; }
  .skill-expand.open { display: block; }
  .expand-list { margin: 0; padding-left: 16px; list-style: disc; }
  .expand-list li { font-size: 11px; color: var(--gray); padding: 2px 0; line-height: 1.5; }

  /* 태그 */
  .tag-list { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 8px; }

  .tag {
    font-size: 11px;
    padding: 3px 8px;
    border-radius: 4px;
    background: var(--sidebar);
    color: var(--gray);
    border: 1px solid var(--border);
  }

  /* 서비스 경험 칩 — 강조색 (도메인/플랫폼과 시각 구분) */
  .tag.tag-service {
    background: var(--org-lt, rgba(196,80,0,0.08));
    color: var(--org);
    border-color: var(--org);
  }
  :root[data-mode="programmer"] .tag.tag-service {
    background: rgba(196,80,0,0.10) !important;
    color: #c45000 !important;
    border-color: rgba(196,80,0,0.4) !important;
  }

  /* 타임라인 뷰 */
  .timeline {
    position: relative;
    padding-left: 24px;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 7px;
    top: 8px;
    bottom: 8px;
    width: 1px;
    background: var(--border);
  }

  .tl-item {
    position: relative;
    margin-bottom: 20px;
  }

  .tl-dot {
    position: absolute;
    left: -21px;
    top: 6px;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--border);
    border: 2px solid var(--bg);
  }

  .tl-item.current .tl-dot {
    background: var(--org);
  }

  .tl-period {
    font-size: 10px;
    color: var(--hint);
    margin-bottom: 3px;
  }

  .tl-co {
    font-size: 13px;
    font-weight: 600;
    color: var(--blk);
  }

  .tl-role {
    font-size: 11px;
    color: var(--org);
    margin-top: 1px;
  }

  .tl-desc {
    font-size: 11px;
    color: var(--muted);
    margin-top: 4px;
  }

  /* 프로필 뷰 */
  .profile-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    margin-bottom: 16px;
  }

  .profile-item { }

  .profile-label {
    font-size: 10px;
    color: var(--hint);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 2px;
  }

  .profile-value {
    font-size: 13px;
    color: var(--blk);
    font-weight: 500;
  }

  /* 햄버거 버튼 */
  .hamburger {
    display: none;
    position: fixed;
    top: 12px;
    left: 12px;
    z-index: 200;
    background: var(--org);
    border: none;
    border-radius: 6px;
    width: 36px;
    height: 36px;
    cursor: pointer;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 5px;
    padding: 0;
  }
  .hamburger span {
    display: block;
    width: 18px;
    height: 2px;
    background: #fff;
    border-radius: 2px;
    transition: all 0.2s;
  }

  /* 모바일 오버레이 */
  .overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.35);
    z-index: 99;
  }
  .overlay.open { display: block; }

  /* 모바일 반응형 */
  @media (max-width: 640px) {
    .hamburger { display: flex; }
    .sidebar {
      position: fixed;
      left: -240px;
      top: 0;
      height: 100%;
      z-index: 100;
      width: 240px;
      transition: left 0.25s ease;
      box-shadow: none;
    }
    .sidebar.open { left: 0; box-shadow: 4px 0 16px rgba(0,0,0,0.12); }
    .main { width: 100%; }
    .topbar { padding-left: 56px; }
  }

  /* 인쇄 */
  @page { margin: 14mm 12mm; }   /* 종이 물리 여백 — 없으면 상단/좌우가 잘림 */
  @media print {
    html, body { height: auto; }
    .sidebar, .topbar { display: none; }
    .main { overflow: visible; }
    .content { padding: 0; overflow: visible; }
    .app { height: auto; display: block; }
    .card { break-inside: avoid; }
    .section-label { margin-top: 0; }   /* 첫 섹션 라벨이 페이지 상단에 붙어 잘리지 않도록 */
  }

  /* 스크롤바 */
  ::-webkit-scrollbar { width: 4px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

  /* ── 프로젝트 위키 (셸 내 네이티브 렌더) ── */
  /* 상단 바(섹션 라벨 + 목차 토글) — 스크롤해도 상단 고정 */
  .pw-bar{ position:sticky; top:0; z-index:6; display:flex; align-items:center; justify-content:space-between; gap:12px; margin:0 0 10px; padding:8px 0; background:var(--bg) }
  /* #content 의 상단 패딩(24px) 틈으로 본문이 비치는 것을 덮는 불투명 띠 (좌우 패딩까지 덮도록 음수 오프셋) */
  .pw-bar::before{ content:''; position:absolute; left:-24px; right:-24px; top:-26px; height:26px; background:var(--bg) }
  .pw-bar .section-label{ flex:1; min-width:0 }
  .pw-toggle{ font:inherit; font-size:12.5px; font-weight:600; color:var(--gray); background:var(--card-hi); border:1px solid var(--border); border-radius:999px; padding:4px 13px; cursor:pointer }
  .pw-toggle:hover{ color:var(--org); border-color:var(--org) }
  .pw-wrap{ display:grid; grid-template-columns:236px minmax(0,1fr); gap:30px; align-items:start }
  .pw-wrap.pw-toc-off{ grid-template-columns:1fr }
  .pw-wrap.pw-toc-off .pw-toc{ display:none }
  .pw-toc{ position:sticky; top:48px; align-self:start; background:var(--card-hi); border:1px solid var(--border); border-radius:12px; overflow:hidden; max-height:calc(100vh - 170px); overflow-y:auto }
  .pw-toc-head{ padding:11px 14px; font-weight:700; font-size:13.5px; color:var(--blk); border-bottom:1px solid var(--border); background:var(--org-lt) }
  .pw-cnt{ color:var(--org); font-weight:700; margin-left:2px }
  .pw-toc-list{ list-style:none; margin:0; padding:8px 6px 12px; font-size:13px }
  .pw-toc-list li{ margin:0 }
  .pw-toc-list a{ display:flex; gap:7px; padding:4px 10px; border-radius:6px; color:var(--gray); text-decoration:none; align-items:baseline; line-height:1.4 }
  .pw-toc-list a:hover{ background:var(--hover); color:var(--blk) }
  .pw-toc-list a.active{ background:var(--org-lt); color:var(--org); font-weight:600 }
  .pw-n{ color:var(--org); font-weight:700; flex-shrink:0; font-variant-numeric:tabular-nums }
  .pw-tname{ flex:1; min-width:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap }
  .pw-doc-sub{ color:var(--muted); font-size:13px; margin:0 0 6px }
  /* 말단(짧은) 섹션도 상단까지 스크롤되어 목차 클릭/하이라이트가 동작하도록 하단 여유 */
  .pw-doc{ padding-bottom:70vh }
  .pw-proj{ padding:0 0 10px; margin:0 0 18px; border-bottom:1px solid var(--border); scroll-margin-top:56px }
  .pw-proj:last-child{ border-bottom:0 }
  .pw-name{ font-size:18px; font-weight:700; color:var(--blk); margin:18px 0 8px }
  .pw-name:first-child{ margin-top:6px }
  .pw-num{ color:var(--org) }
  .pw-chips{ display:flex; flex-wrap:wrap; gap:6px; margin:0 0 6px }
  .pw-chip{ font-size:11.5px; font-weight:700; padding:2px 9px; border-radius:999px; background:var(--card-hi); color:var(--gray); border:1px solid var(--border) }
  .pw-chip.key{ background:var(--org-lt); color:var(--org); border-color:transparent }
  .pw-chip.period{ font-variant-numeric:tabular-nums; color:var(--muted) }
  .pw-meta{ font-size:13px; color:var(--gray); margin:0 0 8px }
  .pw-meta .pw-appeal{ color:var(--org); font-weight:600 }
  .pw-summary{ margin:.1em 0 .5em }
  /* 서브프로젝트 헤더 (group) */
  .pw-group{ font-size:15px; font-weight:700; color:var(--blk); margin:18px 0 8px; padding-bottom:5px; border-bottom:2px solid var(--border) }
  .pw-group:first-child{ margin-top:4px }
  /* 내용별 박스 (목업: 각 섹션 = 카드, 성과 = 초록) */
  .pw-sec{ border:1px solid var(--border); border-left:3px solid var(--org); border-radius:0 9px 9px 0; padding:11px 15px; margin:10px 0; background:var(--white) }
  .pw-sec.hi{ border-color:#4a9d7f; border-left-color:#4a9d7f; background:rgba(74,157,127,.07) }
  .pw-sec-h{ font-weight:700; color:var(--org); margin:0 0 6px; font-size:14px }
  .pw-sec.hi .pw-sec-h{ color:#2f8f63 }
  .pw-md{ font-size:14.5px; line-height:1.72; color:var(--blk) }
  .pw-md > :first-child{ margin-top:0 } .pw-md > :last-child{ margin-bottom:0 }
  .pw-md strong{ font-weight:700; color:var(--blk) }
  .pw-md ul,.pw-ul{ margin:.4em 0; padding-left:1.4em }
  .pw-md li,.pw-ul li{ margin:.22em 0 }
  .pw-ul{ list-style:disc }
  .pw-md strong{ font-weight:700 }
  .pw-md table{ border-collapse:collapse; width:100%; margin:.8em 0; font-size:13.5px }
  .pw-md th,.pw-md td{ border:1px solid var(--border); padding:7px 10px; text-align:left; vertical-align:top }
  .pw-md th{ background:var(--org-lt) }
  .pw-md code{ font-family:inherit; font-size:.9em; background:var(--card-hi); padding:1px 5px; border-radius:4px }
  .pw-md pre{ background:var(--card-hi); padding:12px 14px; border-radius:8px; overflow:auto; margin:.7em 0 }
  .pw-md pre code{ background:none; padding:0 }
  .pw-md blockquote{ border-left:3px solid var(--org); background:var(--org-lt); padding:.5em 1em; margin:.7em 0; border-radius:0 8px 8px 0; color:var(--gray) }
  .pw-att{ display:flex; flex-wrap:wrap; gap:12px; margin:.5em 0; font-size:13px }
  .pw-att a{ color:var(--org) }
  @media print{ .pw-bar{display:none} .pw-wrap{grid-template-columns:1fr} .pw-toc{display:none} .pw-doc{padding-bottom:0} }

  /* ── 연혁 (간단 연대표) ── */
  .hist-row{ display:flex; gap:14px; padding:10px 0; border-bottom:1px solid var(--border) }
  .hist-row:last-child{ border-bottom:0 }
  .hist-period{ flex:0 0 120px; font-size:12.5px; color:var(--org); font-weight:700; font-variant-numeric:tabular-nums }
  .hist-body{ flex:1; min-width:0 }
  .hist-name{ font-size:14px; font-weight:700; color:var(--blk) }
  .hist-role{ font-weight:500; color:var(--gray); font-size:12.5px }
  .hist-desc{ font-size:12.5px; color:var(--gray); margin-top:3px; line-height:1.6; white-space:pre-wrap }
  @media (max-width:560px){ .hist-row{ flex-direction:column; gap:2px } .hist-period{ flex:none } }

  /* ── 웹 편집기 (셸 내장) ── */
  .fab-edit{position:fixed; right:22px; bottom:22px; z-index:900; background:var(--org); color:#fff; border:0; border-radius:999px; padding:11px 20px; font:inherit; font-weight:700; font-size:14px; cursor:pointer; box-shadow:0 4px 16px rgba(0,0,0,.25)}
  .ed-scrim{position:fixed; inset:0; background:rgba(0,0,0,.35); z-index:998; opacity:0; pointer-events:none; transition:.2s}
  .ed-scrim.open{opacity:1; pointer-events:auto}
  .ed-drawer{position:fixed; top:0; right:0; bottom:0; width:min(560px,94vw); background:var(--white); border-left:1px solid var(--border); box-shadow:-8px 0 30px rgba(0,0,0,.14); z-index:999; transform:translateX(100%); transition:transform .22s; display:flex; flex-direction:column}
  .ed-drawer.open{transform:none}
  .ed-head{display:flex; align-items:center; gap:8px; padding:13px 16px; border-bottom:1px solid var(--border)}
  .ed-head .t{font-weight:700; color:var(--blk)}
  .ed-head .sp{flex:1}
  .ed-body{flex:1; overflow:auto; padding:12px 16px}
  .ed-foot{display:flex; gap:8px; padding:11px 16px; border-top:1px solid var(--border); align-items:center}
  .ed-foot .msg{flex:1; font-size:12px; color:var(--muted)}
  .ed-btn{font:inherit; font-size:13px; font-weight:600; padding:6px 12px; border-radius:8px; border:1px solid var(--border); background:var(--card-hi); color:var(--blk); cursor:pointer}
  .ed-btn.solid{background:var(--org); color:#fff; border-color:var(--org)}
  .ed-btn.ghost{background:none}
  .fe-tabs{display:flex; gap:4px; flex-wrap:wrap; position:sticky; top:0; background:var(--white); padding:2px 0 8px; margin-bottom:8px; border-bottom:1px solid var(--border); z-index:2}
  .fe-tab{font:inherit; font-size:12.5px; font-weight:600; padding:5px 11px; border:1px solid var(--border); background:var(--card-hi); color:var(--gray); border-radius:999px; cursor:pointer}
  .fe-tab.on{background:var(--org); color:#fff; border-color:var(--org)}
  .fe-proj{border:1px solid var(--border); border-radius:10px; padding:10px 12px; margin:0 0 12px; background:var(--card-hi)}
  .fe-h{display:flex; align-items:center; gap:8px; margin-bottom:8px}
  .fe-h b{color:var(--org); font-size:13px; flex-shrink:0}
  .fe-grid{display:grid; grid-template-columns:1fr 1fr; gap:6px; margin-bottom:6px}
  .fe-sec{border-left:3px solid var(--border); padding:6px 0 6px 10px; margin:8px 0}
  .fe-sec.hi{border-left-color:#4a9d7f}
  .fe-srow{display:flex; gap:6px; align-items:center; margin-bottom:4px; flex-wrap:wrap}
  .ed-drawer input[type=text], .ed-drawer textarea{width:100%; min-width:0; font:inherit; font-size:13px; padding:5px 8px; border:1px solid var(--border); border-radius:6px; background:var(--white); color:var(--blk)}
  .ed-drawer .fe-h input{flex:1}
  .ed-drawer textarea{min-height:62px; resize:vertical; line-height:1.5}
  .fe-lbl{font-size:12px; color:var(--gray); display:flex; align-items:center; gap:4px; white-space:nowrap}
  .fe-fl{display:block; margin:0 0 7px; font-size:12px; color:var(--gray)}
  .fe-fl>span{display:block; margin-bottom:2px}
  .fe-del{background:none; border:1px solid var(--border); border-radius:6px; color:var(--muted); cursor:pointer; font-size:12px; padding:3px 9px; flex-shrink:0}
  .fe-del:hover{color:var(--org); border-color:var(--org)}
  .fe-addsec{font:inherit; font-size:12px; background:var(--white); border:1px dashed var(--border); border-radius:6px; color:var(--gray); cursor:pointer; padding:4px 10px; margin-top:2px}
  .fe-ord{font:inherit; font-size:12px; background:var(--white); border:1px solid var(--border); border-radius:6px; color:var(--gray); cursor:pointer; padding:3px 8px; flex-shrink:0}
  .fe-ord:hover:not(:disabled){color:var(--org); border-color:var(--org)}
  .fe-ord:disabled{opacity:.3; cursor:default}
  .fe-drop{border:1px dashed var(--border); border-radius:8px; padding:10px; margin:6px 0; text-align:center; font-size:12px; color:var(--muted); background:var(--white); transition:.12s}
  .fe-drop.over{border-color:var(--org); background:var(--card-hi); color:var(--org)}
  .fe-pick{display:inline-block; cursor:pointer; color:var(--org); text-decoration:underline; text-underline-offset:2px}
  .fe-thumb{display:block; max-width:100%; max-height:160px; margin:0 auto 8px; border-radius:6px; border:1px solid var(--border)}
  .fe-imgrow{display:flex; gap:6px; align-items:center; margin-top:6px}
  .fe-imgrow input{flex:1}
  @media print{ .fab-edit,.ed-scrim,.ed-drawer{display:none !important} }
  html[data-export] .fab-edit, html[data-export] .ed-scrim, html[data-export] .ed-drawer{ display:none !important }

  /* 스크롤바 */
  ::-webkit-scrollbar { width: 4px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }
</style>
