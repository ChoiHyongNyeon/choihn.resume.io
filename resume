// 경력 요약 뷰
function renderCareerSummary(list) {
  // department 키가 의미상 '프로젝트명' (라벨은 사용자 설정), c.project 는 호환 폴백
  const projectOf = c => c.project || c.department || '';
  // 요약 뷰에 표시할 핵심 항목 — summary_bullets 우선, 비어있으면 bullets 앞 3줄 폴백
  const summaryBulletsOf = c => {
    if (c.summary_bullets && c.summary_bullets.length) return c.summary_bullets;
    return (c.bullets || []).slice(0, 3);
  };

  // 최근/이전 분류 기준 — DATA.career_recent_year (사용자 설정).
  // 빈 값이거나 숫자 아니면 분류 없이 전체를 한 섹션에.
  const thRaw = (DATA.career_recent_year || '').toString().trim();
  const threshold = (thRaw && /^\d+$/.test(thRaw)) ? parseInt(thRaw, 10) : null;

  // 카드 렌더 헬퍼 — 최근/이전 동일 구조
  function renderCard(c) {
    const sb = summaryBulletsOf(c);
    return `
      <div class="card ${c.status === '재직중' ? 'highlight' : ''}">
        <div class="card-head">
          <span class="card-co">${c.company || ''}</span>
          <span class="card-period">${c.period || ''}</span>
          ${c.status ? `<span class="badge">${c.status}</span>` : ''}
        </div>
        ${projectOf(c) ? `<div class="card-project">${projectOf(c)}</div>` : ''}
        ${c.role ? `<div class="card-role">${c.role}</div>` : ''}
        ${c.summary ? `<div class="card-summary">${fmt(c.summary)}</div>` : ''}
        ${sb.length ? `
          <ul class="bullets">
            ${sb.map(b => `<li>${fmt(b)}</li>`).join('')}
          </ul>` : ''}
      </div>
    `;
  }

  let html = '';
  if (threshold == null) {
    // 분류 없음 — 한 섹션에
    if (list.length) {
      html += '<div class="section-label">경력 요약</div>';
      html += list.map(renderCard).join('');
    }
  } else {
    const yearOf = c => parseInt((c.period || '').slice(0, 4), 10);
    const recent = list.filter(c => yearOf(c) >= threshold);
    const oldList = list.filter(c => !(yearOf(c) >= threshold));
    if (recent.length) {
      html += '<div class="section-label">최근 경력</div>';
      html += recent.map(renderCard).join('');
    }
    if (oldList.length) {
      html += '<div class="section-label" style="margin-top:20px;">이전 경력</div>';
      html += oldList.map(renderCard).join('');
    }
  }
  return html;
}

